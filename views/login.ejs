

<!DOCTYPE html>
<head>
    <title>Login</title>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap');

        body{
            margin:0;
            padding:0;
            font-family:'Inter', sans-serif;
            background:#f4f6f8;
            height:100vh;
            display:flex;
            justify-content:center;
            align-items:center;
        }

        form{
            background:#fff;
            padding:25px;
            border-radius:12px;
            box-shadow:0 6px 18px rgba(0,0,0,0.08);
            width:320px;
        }

        label{
            display:block;
            margin-top:10px;
            font-size:14px;
            font-weight:500;
            color:#333;
        }

        input{
            width:100%;
            padding:10px;
            margin-top:5px;
            border:1px solid #ddd;
            border-radius:8px;
            outline:none;
            font-size:14px;
        }

        input:focus{
            border-color:#4f46e5;
        }

        .links{
            display:flex;
            justify-content:space-between;
            margin-top:10px;
            font-size:13px;
        }

        a{
            color:#4f46e5;
            text-decoration:none;
        }

        a:hover{
            text-decoration:underline;
        }

        button{
            width:100%;
            margin-top:15px;
            padding:10px;
            border:none;
            border-radius:8px;
            background:#4f46e5;
            color:#fff;
            font-weight:500;
            cursor:pointer;
        }

        button:hover{
            background:#4338ca;
        }

        /* 🔥 Success Message */
        .success-msg{
            background:#d1fae5;
            color:#065f46;
            padding:10px;
            border-radius:6px;
            font-size:13px;
            margin-bottom:10px;
            text-align:center;
        }
         .error{
            color:#b91c1c;
            background:#fee2e2;
            padding:8px;
            border-radius:6px;
            margin-bottom:10px;
            font-size:13px;
        }
    </style>
</head>

<body>
    <form action="/user/login" method="post">

       <% if (typeof verified !== "undefined" && verified) { %>
    <div class="success-msg">OTP Verified Successfully ✅</div>
<% } %>

 <% if (typeof error !== "undefined") { %>
            <div class="error"><%= error %></div>
        <% } %>

        <label>Email</label>
        <input type="text" name="email" required>

        <label>Password</label>
        <input type="password" name="password" required>

        <div class="links">
            <a href="forgetPassword">forget password</a>
            <a href="/signup">don't have an account?</a>
        </div>

        <button type="submit">Login</button>

    </form>
</body>